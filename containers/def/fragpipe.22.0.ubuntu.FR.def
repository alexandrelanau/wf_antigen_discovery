Bootstrap: docker
From: fcyucn/fragpipe:22.0

%post
    # Install locales and generate the required locale
    apt-get update
    apt-get install -y locales
    locale-gen fr_FR.UTF-8
    update-locale LANG=fr_FR.UTF-8

%test
    /fragpipe_bin/fragPipe-22.0/fragpipe/bin/fragpipe --help || echo "FragPipe is not found!"
